# ── 复制此文件为 .env，填入真实值，.env 不提交 Git ──────────

# LLM 配置（使用 DeepSeek）
LLM_API_KEY=sk-请填入你的DeepSeek-API-Key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 嵌入模型（本地运行，Kaggle 可用）
EMBED_MODEL=BAAI/bge-small-zh-v1.5

# 数据库路径
CHROMA_PATH=./db/chroma
SQLITE_PATH=./db/app.db

# 文件目录
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# 服务配置
HOST=0.0.0.0
PORT=8000

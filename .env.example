# ── 复制此文件为 .env，填入真实值，.env 不提交 Git ──────────

# LLM 配置（使用 Ollama 本地部署，完全免费）
# 1. 下载安装 Ollama：https://ollama.com/download
# 2. 终端运行：ollama pull qwen3:8b
# 3. Ollama 会自动在 http://localhost:11434 启动服务
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b

# 嵌入模型（本地运行，Kaggle 可用）
EMBED_MODEL=BAAI/bge-small-zh-v1.5

# 数据库路径
CHROMA_PATH=./db/chroma
SQLITE_PATH=./db/app.db

# 文件目录
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# 服务配置
HOST=0.0.0.0
PORT=8000

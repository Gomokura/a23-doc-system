# ── 复制此文件为 .env，填入真实值，.env 不提交 Git ──────────

# LLM 配置（使用 Ollama 本地部署，完全免费）
# 1. 下载安装 Ollama：https://ollama.com/download
# 2. 终端运行（推荐低配拆分，避免问答时 OOM）：
#    ollama pull qwen2.5:1.5b
#    ollama pull qwen2.5vl:3b
#    ollama pull nomic-embed-text
# 3. Ollama 会自动在 http://localhost:11434 启动服务
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:1.5b
# 仅 PDF 逐页视觉解析用；不配则 PDF 也使用 LLM_MODEL
PDF_VLM_MODEL=qwen2.5vl:3b

# 嵌入模型：必须与 Ollama 里已 pull 的模型名一致（不要用 HuggingFace 全名如 BAAI/bge-...）
EMBED_MODEL=nomic-embed-text

# 数据库路径
CHROMA_PATH=./db/chroma
SQLITE_PATH=./db/app.db

# 文件目录
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# 服务配置
HOST=0.0.0.0
PORT=8000
